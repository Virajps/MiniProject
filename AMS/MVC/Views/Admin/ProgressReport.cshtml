@{
    ViewData["Title"] = "Employee Progress Report";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

@section Styles {
<style>
.report-container {
    max-width: 1300px;
    margin: auto;
}

.filters {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}

#profileCard {
    background: #1c7ed6;
    color: white;
    padding: 18px;
    border-radius: 10px;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
}

.chart-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

#attendanceChart,
#taskChart {
    background: white;
    border-radius: 10px;
    box-shadow: 0 3px 8px rgba(0, 0, 0, 0.15);
}

#exportArea{
    background:white;
    padding:20px;
}

#summaryGrid,
#taskGrid {
    margin-top: 20px;
}

.k-grid-toolbar {
    background: #1c7ed6;
    color: white;
}

#exportArea{
    background:white;
    padding:20px;
}

.chart-row{
    page-break-inside: avoid;
}

a.k-link{
        color:#1ca7ec !important;
    }

    a.k-link:hover{
        color:#0ea5e9 !important;
    }

    .k-state-selected > .k-link,
    .k-selected > .k-link{
        color:#1ca7ec !important;
    }

@@media (max-width: 900px) {
    .chart-row {
        grid-template-columns: 1fr;
    }

    #profileCard {
        flex-direction: column;
        align-items: flex-start;
    }
}
</style>
}

<div class="report-container">

    <div class="filters">
        <div style="flex:1; min-width:200px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Select Employee</label>
            <input id="employee" style="width:100%; padding:8px 12px; border:1px solid #ccc; border-radius:6px;" />
        </div>
        <div style="min-width:140px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Month</label>
            <input id="month" style="width:100%; padding:8px 12px; border:1px solid #ccc; border-radius:6px;" />
        </div>
        <div style="min-width:140px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Year</label>
            <input id="year" style="width:100%; padding:8px 12px; border:1px solid #ccc; border-radius:6px;" />
        </div>
        <div style="align-self:flex-end;">
            <button id="generateReport" style="background-color: #0ea5e9; color:white; border:none; padding:8px 20px; border-radius:6px; cursor:pointer; margin-right:10px;">Generate</button>
            <button id="exportReport" style="background-color: #0ea5e9; color:white; border:none; padding:8px 20px; border-radius:6px; cursor:pointer;">Export PDF</button>
        </div>
    </div>

    <!-- Export Area -->
    <div id="exportArea">

        <div id="profileCard"></div>

        <div class="chart-row">
            <div id="attendanceChart"></div>
            <div id="taskChart"></div>
        </div>

        <div id="summaryGrid"></div>
        <div id="taskGrid"></div>

    </div>

</div>

@section Scripts {

<script>

$(document).ready(function () {



    function renderProfile(data) {
        if (!data) {
            $("#profileCard").html("<div>No data available</div>");
            return;
        }

        const name = data.employeeName || data.EmployeeName || 'Unknown';
        const empId = data.employeeId || data.EmployeeId || 'N/A';
        const email = data.email || data.Email || data.employeeEmail || data.EmployeeEmail || 'N/A';
        const hours = data.totalWorkingHours || data.TotalWorkingHours || 0;

        $("#profileCard").html(`
            <div>
                <h3>${name}</h3>
                <span>Employee ID : ${empId}</span>
                <span style="display:block; margin-top:5px;">Email : ${email}</span>
            </div>

            <div>
                <b>Total Working Hours :</b> ${hours}
            </div>
        `);
    }

    function renderCharts(data) {
        if (!data) {
            alert("No data to render");
            return;
        }

        try {
            // Destroy existing charts if they exist
            var attendanceChart = $("#attendanceChart").data("kendoChart");
            if (attendanceChart) {
                attendanceChart.destroy();
            }
            
            var taskChart = $("#taskChart").data("kendoChart");
            if (taskChart) {
                taskChart.destroy();
            }

            // Clear the divs
            $("#attendanceChart").empty();
            $("#taskChart").empty();

            $("#attendanceChart").kendoChart({
                title: { text: "Attendance Overview" },
                chartArea: { height: 400 },
                seriesColors: ["#166f99", "#2185b4","#B0DFE5", "#319fd2", "#3eaee2", "#89CFF0"],
                series: [{
                    type: "column",
                    overlay:{ gradient:"none" },
                    data: [
                        data.totalAttendance || 0,
                        data.present || 0,
                        data.lateIn || 0,
                        data.earlyOut || 0,
                        data.absent || 0
                    ]
                }],
                categoryAxis: {
                    categories: ["Total", "Regular", "Late", "Early Out", "Absent"]
                }
            });

            const taskData = (data.tasks && Array.isArray(data.tasks) && data.tasks.length > 0)
                ? data.tasks.map(t => ({
                    category: t.taskType || 'Unknown',
                    value: t.hours || 0
                }))
                : [];

            if (taskData.length > 0) {
                $("#taskChart").kendoChart({
                    title: { text: "Task Distribution" },
                    seriesColors: ["#166f99", "#2185b4","#B0DFE5", "#319fd2", "#3eaee2", "#89CFF0"],
                    seriesDefaults: {
                        type: "donut",
                        startAngle: 300
                    },
                    series: [{
                        data: taskData,
                        overlay:{ gradient:"none" }
                    }]
                });
            } else {
                $("#taskChart").html("<div style='padding:20px; text-align:center;'>No task data available</div>");
            }
        } catch (err) {
            console.error("Error rendering charts:", err);
            alert("Error rendering charts: " + err.message);
        }
    }



    function renderGrids(data) {
        if (!data) {
            alert("No data to render");
            return;
        }

        try {
            // Destroy existing grids if they exist
            var summaryGrid = $("#summaryGrid").data("kendoGrid");
            if (summaryGrid) {
                summaryGrid.destroy();
            }
            
            var taskGrid = $("#taskGrid").data("kendoGrid");
            if (taskGrid) {
                taskGrid.destroy();
            }

            $("#summaryGrid").kendoGrid({
                dataSource: [{
                    totalAttendance: data.totalAttendance || 0,
                    present: data.present || 0,
                    lateIn: data.lateIn || 0,
                    earlyOut: data.earlyOut || 0,
                    absent: data.absent || 0,
                    totalWorkingHours: data.totalWorkingHours || 0
                }],
                columns: [
                    { field: "totalAttendance", title: "Total Attendance" },
                    { field: "present", title: "Regular" },
                    { field: "lateIn", title: "Late" },
                    { field: "earlyOut", title: "Early Out" },
                    { field: "absent", title: "Absent" },
                    { field: "totalWorkingHours", title: "Working Hours" }
                ]
            });

            const taskDataSource = (data.tasks && Array.isArray(data.tasks)) ? data.tasks : [];
            
            $("#taskGrid").kendoGrid({
                dataSource: taskDataSource,
                columns: [
                    { field: "taskType", title: "Task Type" },
                    { field: "hours", title: "Hours" }
                ],
                noRecords: {
                    template: "No tasks recorded"
                }
            });
        } catch (err) {
            console.error("Error rendering grids:", err);
            alert("Error rendering grids: " + err.message);
        }
    }



    $("#employee").kendoDropDownList({
        optionLabel: "Select Employee",
        dataTextField: "name",
        dataValueField: "id",
        dataSource: {
            transport: {
                read: {
                    url: "/Admin/GetEmployeeDropdownList",
                    dataType: "json"
                }
            },
            schema: {
                data: "data"
            }
        }
    });

    $("#month").kendoDropDownList({
        dataSource: [
            { text: "January", value: 1 },
            { text: "February", value: 2 },
            { text: "March", value: 3 },
            { text: "April", value: 4 },
            { text: "May", value: 5 },
            { text: "June", value: 6 },
            { text: "July", value: 7 },
            { text: "August", value: 8 },
            { text: "September", value: 9 },
            { text: "October", value: 10 },
            { text: "November", value: 11 },
            { text: "December", value: 12 }
        ],
        dataTextField: "text",
        dataValueField: "value",
        value: new Date().getMonth() + 1
    });

    $("#year").kendoDropDownList({
        dataSource: [2024, 2025, 2026],
        value: new Date().getFullYear()
    });



    $("#generateReport").kendoButton({
        themeColor: "primary",
        click: function () {
            const emp = $("#employee").data("kendoDropDownList").value();
            const month = $("#month").data("kendoDropDownList").value();
            const year = $("#year").data("kendoDropDownList").value();

            if (!emp) {
                alert("Please select an employee");
                return;
            }

            if (!month || !year) {
                alert("Please select month and year");
                return;
            }

            $.ajax({
                url: "/Admin/GetEmployeeProgress",
                type: "GET",
                data: { empId: emp, month: month, year: year },
                success: function (data) {
                    console.log("Response Data:", data);
                    
                    if (!data || !data.success) {
                        alert("Failed to load report data: " + (data?.message || "Unknown error"));
                        console.error("Response not successful:", data);
                        return;
                    }

                    if (!data.data) {
                        alert("No data found for selected employee");
                        console.warn("No data in response:", data);
                        return;
                    }

                    const reportData = data.data;
                    console.log("Report Data to Render:", reportData);
                    
                    try {
                        renderProfile(reportData);
                        renderCharts(reportData);
                        renderGrids(reportData);
                    } catch (err) {
                        console.error("Error rendering report:", err);
                        alert("Error rendering report: " + err.message);
                    }
                },
                error: function (xhr) {
                    console.error("AJAX Error:", xhr);
                    alert("Error loading report: " + (xhr.responseJSON?.message || xhr.statusText || "Server error"));
                }
            });
        }
    });

    $("#exportReport").kendoButton({
        themeColor: "primary",
        click: function () {
            const emp = $("#employee").data("kendoDropDownList").value();
            const month = $("#month").data("kendoDropDownList").value();
            const year = $("#year").data("kendoDropDownList").value();

            if (!emp || !month || !year) {
                alert("Please generate report first");
                return;
            }

            const fileName = "report_" + emp + "_" + month + "_" + year + ".pdf";

            kendo.drawing.drawDOM($("#exportArea"), {
                paperSize: "A4",
                margin: "1cm",
                scale: 0.6,              
                landscape: true,         
                forcePageBreak: ".page-break"
            }).then(function (group) {
                kendo.drawing.pdf.saveAs(group, fileName);
            }).catch(function(err) {
                alert("Error generating PDF: " + err);
            });
        }
    });

});

</script>

}
