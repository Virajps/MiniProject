@{
    ViewData["Title"] = "History";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

@section Styles {
<style>
    .scheduler-container{
        max-width:1350px;
        margin-left:20px;
    }

    #employeeSelect{
        padding:8px 12px;
        border-radius:8px;
        border:1px solid #ccc;
        font-size:14px;
        margin-bottom:15px;
    }

    #scheduler{
        margin-top:20px;
        border-radius:12px;
        overflow:hidden;
        box-shadow:0 6px 18px rgba(0,0,0,0.15);
    }

    .k-scheduler-toolbar{
        background:#3f72af;
        color:white;
    }

    .k-scheduler-toolbar .k-button{
        border-radius:6px;
        margin-left:4px;
    }

    .k-scheduler-toolbar .k-button.k-selected{
        background:#112d4e;
        color:white;
        border-color: #112d4e;
    }

    .k-scheduler-monthview td{
        border:1px solid #e6e6e6;
    }

    .k-scheduler-monthview .k-scheduler-table td:hover{
        background:#f5f7fa;
    }

    .k-scheduler-monthview .k-scheduler-table td:nth-child(1){
        background:#f0f0f0 !important;
        color:#999;
    }

    .k-event{
        border:none !important;
        background:none !important;
        padding:0 !important;
        box-shadow:none !important;
    }

    .attendance-event{
        display:flex;
        justify-content:center;
        align-items:center;
        width:100%;
        height:100%;
        font-size:15px;
        font-weight:600;
        border-radius:4px;
    }

    .Regular{
        background:#4CAF50;
        color:white;
    }

    .LateIn{
        background:#FFC107;
        color:black;
    }

    .EarlyOut{
        background:#FF7043;
        color:white;
    }

    .Absent{
        background:#F44336;
        color:white;
    }

    .k-scheduler-weekview .k-event{
        text-align: center;
        margin-left: 0.5%;
    }

    .k-scheduler-weekview .k-scheduler-all-day .k-event{
        height:28px;
    }

    a.k-link{
        color:#1ca7ec !important;
    }

    a.k-link:hover{
        color:#0ea5e9 !important;
    }

    .k-state-selected > .k-link,
    .k-selected > .k-link{
        color:#1ca7ec !important;
    }

    .Holiday{
        background:#90a4ae;
        color:white;
    }

</style>
}
<div class="scheduler-container">

    <div style="margin-bottom:20px; display:flex; gap:10px; align-items:center;">
        <div class="row">
            <div class="col">
                <select id="employeeSelect"
                        style="width:300px; padding:8px 12px; border-radius:8px; border:1px solid #ccc; font-size:14px;"></select>
            </div>
            <div class="col">
                <input id="searchEmployee" type="text" placeholder="Search employee..."
                       style="padding:8px 12px; border:1px solid #ccc; border-radius:6px; width:250px; font-size:14px;" />
            </div>
        </div>
    </div>

    <div style="margin-bottom:10px;font-size:13px;font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;">
        <span style="background:#4CAF50;padding:5px 10px;border-radius:6px;color:white;">Regular</span>
        <span style="background:#FFC107;padding:5px 10px;border-radius:6px;">LateIn</span>
        <span style="background:#ff7043;padding:5px 10px;border-radius:6px;color:white;">EarlyOut</span>
        <span style="background:#ef5350;padding:5px 10px;border-radius:6px;color:white;">Absent</span>
    </div>
    <div id="scheduler"></div>
</div>

@section Scripts {
<script>
    let schedulerInitialized = false;
    let currentSchedulerDate = new Date();

    $(document).ready(function () {
        let employees = [];

        $.get("/Admin/GetEmployeeDropdownList", function (res) {
            if (res.success && res.data) {
                employees = res.data;
                
                employees.forEach(emp => {
                    $("#employeeSelect").append(
                        `<option value="${emp.id}">${emp.name}</option>`
                    );
                });

                if (employees.length > 0) {
                    initializeScheduler(employees[0].id);
                    $("#employeeSelect").val(employees[0].id);
                }
            }
        });

        // Search functionality
        $("#searchEmployee").on("keyup", function() {
            let searchTerm = $(this).val().toLowerCase();
            $("#employeeSelect").empty();
            
            employees
                .filter(emp => (emp.name || "").toLowerCase().includes(searchTerm))
                .forEach(emp => {
                    $("#employeeSelect").append(
                        `<option value="${emp.id}">${emp.name}</option>`
                    );
                });
            
            if ($("#employeeSelect").find("option").length > 0) {
                $("#employeeSelect").val($("#employeeSelect").find("option:first").val()).trigger("change");
            }
        });

        // On dropdown change, reload scheduler data
        $("#employeeSelect").change(function () {
            if (schedulerInitialized) {
                let scheduler = $("#scheduler").data("kendoScheduler");
                if (scheduler) {
                    scheduler.dataSource.read();
                }
            }
        });
    });

    function toDateKey(dateValue) {
        const d = new Date(dateValue);
        const y = d.getFullYear();
        const m = String(d.getMonth() + 1).padStart(2, "0");
        const day = String(d.getDate()).padStart(2, "0");
        return `${y}-${m}-${day}`;
    }

    function buildMonthStatusData(rawEvents, monthDate) {
        const list = Array.isArray(rawEvents) ? rawEvents : [];
        const eventMap = {};
        const today = new Date();
        const todayOnly = new Date(today.getFullYear(), today.getMonth(), today.getDate());
        const year = monthDate.getFullYear();
        const month = monthDate.getMonth();
        const totalDays = new Date(year, month + 1, 0).getDate();
        const result = [];

        list.forEach(function (item) {
            const sourceDate = new Date(item.start || item.Start);
            if (sourceDate.getFullYear() !== year || sourceDate.getMonth() !== month) {
                return;
            }

            const key = toDateKey(sourceDate);
            eventMap[key] = item;
        });

        for (let day = 1; day <= totalDays; day++) {
            const date = new Date(year, month, day);
            const weekDay = date.getDay();

            if (weekDay === 0 || date > todayOnly) {
                continue;
            }

            const key = toDateKey(date);
            const existing = eventMap[key];

            if (existing) {
                const startValue = new Date(year, month, day, 12, 0, 0);
                const endValue = new Date(year, month, day, 12, 30, 0);

                result.push({
                    id: existing.id || existing.Id || `${key}-attendance`,
                    title: existing.title || existing.Title || "Attendance",
                    start: startValue,
                    end: endValue,
                    status: existing.status || existing.Status || "Regular",
                    workingHour: existing.workingHour || existing.WorkingHour || 0,
                    isAllDay: false
                });
            } else {
                result.push({
                    id: `${key}-absent`,
                    title: "Attendance",
                    start: new Date(year, month, day, 12, 0, 0),
                    end: new Date(year, month, day, 12, 30, 0),
                    status: "Absent",
                    workingHour: 0,
                    isAllDay: false
                });
            }
        }

        return result;
    }

    function initializeScheduler(empId) {
        $("#scheduler").kendoScheduler({
            date: new Date(),
            height: 600,
            editable: false,
            views: [
                { type: "month", selected: true },
                "week",
                "agenda"
            ],
            dataSource: {
                transport: {
                    read: function (options) {
                        $.ajax({
                            url: "/Admin/GetAttendanceScheduler",
                            dataType: "json",
                            type: "GET",
                            data: {
                                empId: $("#employeeSelect").val() || empId
                            },
                            success: function (response) {
                                options.success(buildMonthStatusData(response, currentSchedulerDate));
                            },
                            error: function (xhr) {
                                options.error(xhr);
                            }
                        });
                    },
                },
                schema: {
                    model: {
                        id: "id",
                        fields: {
                            id: { from: "id" },
                            title: { from: "title" },
                            start: { from: "start", type: "date" },
                            end: { from: "end", type: "date" },
                            status: { from: "status" },
                            workingHour: { from: "workingHour" },
                            isAllDay: { from: "isAllDay", defaultValue: true }
                        }
                    }
                }
            },
            navigate: function (e) {
                currentSchedulerDate = e.date;
                $("#scheduler").data("kendoScheduler").dataSource.read();
            },
            eventTemplate: `
                <div class="attendance-event #= status #">
                    <span>#= status #</span>
                </div>
            `
        });
        
        schedulerInitialized = true;
        
        // Initial load
        setTimeout(function() {
            let scheduler = $("#scheduler").data("kendoScheduler");
            if (scheduler) {
                scheduler.dataSource.read();
            }
        }, 100);
    }
</script>
}
