<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>

    <link rel="preconnect" href="https://cdn-uicons.flaticon.com" crossorigin />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-layout.css" asp-append-version="true" />
    <link rel='stylesheet'
          href='https://cdn-uicons.flaticon.com/3.0.0/uicons-regular-rounded/css/uicons-regular-rounded.css' />
    @await RenderSectionAsync("Styles", required: false)

    <style>
            :root {
                --sidebar-width: 250px;
                --topbar-height: 64px;
            }

            html,
            body {
                height: 100%;
            }

            body {
                background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
            }

            .admin-sidebar {
                width: var(--sidebar-width);
                height: 100vh;
                top: 0;
            }

            .admin-topbar {
                height: var(--topbar-height);
                z-index: 20;
            }

            #adminSidebarPanelBar {
                border: none;
                background: transparent;
            }

            #adminSidebarPanelBar .k-link {
                border-radius: 0.5rem;
                margin: 0.2rem 0;
                font-weight: 600;
                color: #1f2937;
            }

            /* Active sidebar item */

            #adminSidebarPanelBar .k-selected>.k-link,
            #adminSidebarPanelBar .k-state-selected>.k-link {
                background: #e0f2fe;
                color: #1ca7ec;
            }

            /* Sidebar hover */

            #adminSidebarPanelBar .k-link:hover {
                background: #f0f9ff;
                color: #1ca7ec;
            }

            /* Profile menu */

            #profileMenu {
                border: none;
                background: transparent;
            }

            #profileMenu>.k-item>.k-link {
                padding: 0;
                border: none;
                background: transparent;
            }

            #profileMenu .k-animation-container {
                margin-top: 0.5rem;
            }

            /* Profile icon */

            .profile-trigger {
                width: 42px;
                height: 42px;
                border-radius: 50%;
                border: 2px solid #1ca7ec;
                background: #e0f2fe;
                overflow: hidden;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
            }

            .profile-trigger img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

            .profile-trigger .k-icon {
                color: #1ca7ec;
            }
            
        .bell-wrapper {
            position: relative;
        }

        .bell-icon {
            position: relative;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid #d6e0ea;
            background: linear-gradient(180deg, #ffffff 0%, #eef4f8 100%);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #3b4b5c;
            box-shadow: 0 8px 18px rgba(148, 163, 184, 0.16);
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
        }

        .bell-icon:hover {
            transform: translateY(-1px);
            border-color: #b8d7e8;
            background: linear-gradient(180deg, #ffffff 0%, #e4f4fb 100%);
            box-shadow: 0 12px 24px rgba(56, 189, 248, 0.16);
        }

        .bell-icon.active {
            border-color: #8dd4f5;
            background: linear-gradient(180deg, #fdfefe 0%, #dff4fd 100%);
            box-shadow: 0 14px 28px rgba(14, 165, 233, 0.2);
        }

        .bell-icon::after {
            content: "";
            position: absolute;
            inset: -3px;
            border-radius: 50%;
            border: 1px solid rgba(28, 167, 236, 0.18);
            opacity: 0;
            transform: scale(0.92);
            transition: opacity 0.18s ease, transform 0.18s ease;
            pointer-events: none;
        }

        .bell-icon:hover::after,
        .bell-icon.active::after {
            opacity: 1;
            transform: scale(1);
        }

        .notification-count {
            position: absolute;
            top: -6px;
            right: -4px;
            min-width: 20px;
            height: 20px;
            padding: 0 6px;
            border-radius: 999px;
            background: #ef4444;
            color: #ffffff;
            font-size: 11px;
            font-weight: 700;
            line-height: 20px;
            text-align: center;
            box-shadow: 0 6px 14px rgba(239, 68, 68, 0.35);
            border: 2px solid #ffffff;
        }

        .notification-count.is-hidden {
            display: none;
        }

        .icon i {
            transition: transform 0.2s ease;
        }

        .icon:hover i {
            animation: bellRing 0.6s ease;
        }

        @@keyframes bellRing {
            0% { transform: rotate(0); }
            15% { transform: rotate(15deg); }
            30% { transform: rotate(-12deg); }
            45% { transform: rotate(10deg); }
            60% { transform: rotate(-8deg); }
            75% { transform: rotate(5deg); }
            100% { transform: rotate(0); }
        }

        .notification-panel {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            width: min(430px, 90vw);
            background: linear-gradient(180deg, #fcfeff 0%, #f4f8fb 100%);
            border: 1px solid #d9e4ec;
            border-radius: 18px;
            box-shadow: 0 24px 50px rgba(15, 23, 42, 0.18);
            display: none;
            z-index: 60;
            overflow: hidden;
        }

        .notification-panel.show {
            display: block;
            animation: notificationPanelIn 0.2s ease;
        }

        .notification-panel::before {
            content: "";
            position: absolute;
            top: -8px;
            right: 16px;
            width: 16px;
            height: 16px;
            background: #fcfeff;
            border-top: 1px solid #d9e4ec;
            border-left: 1px solid #d9e4ec;
            transform: rotate(45deg);
        }

        .notification-panel-header {
            padding: 14px 18px;
            background: linear-gradient(90deg, #f0f9ff 0%, #ecfeff 100%);
            border-bottom: 1px solid #dbe7ef;
            font-weight: 700;
            color: #1f2937;
            letter-spacing: 0.01em;
        }

        #notificationList {
            max-height: 360px;
            overflow-y: auto;
            padding: 12px;
            background: transparent;
        }

        .notification-section + .notification-section {
            margin-top: 14px;
        }

        .notification-section-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
            padding: 0 2px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #64748b;
        }

        .notification-section-body {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .notification-item {
            background: linear-gradient(180deg, #ffffff 0%, #f7fafc 100%);
            border: 1px solid #dee8ef;
            border-radius: 14px;
            padding: 12px 14px;
            box-shadow: 0 10px 22px rgba(148, 163, 184, 0.1);
            transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
        }

        .notification-item:hover {
            transform: translateY(-1px);
            border-color: #c9dbe7;
            box-shadow: 0 14px 28px rgba(148, 163, 184, 0.16);
        }

        .notification-item strong {
            color: #1f2937;
            font-size: 14px;
        }

        .notification-item span {
            color: #4b5563;
            font-size: 13px;
            line-height: 1.45;
        }

        .notification-time {
            display: block;
            margin-top: 6px;
            color: #7c8a9a;
            font-size: 12px;
        }

        .notification-empty {
            color: #6b7280;
            font-size: 14px;
            text-align: center;
            padding: 22px 12px;
            border: 1px dashed #d5dee7;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.75);
        }

        .remove-queue-message {
            border-radius: 999px;
            padding: 6px 12px;
            border-color: #f3c6ce;
            color: #c24157;
            background: #fff7f8;
            font-size: 12px;
            font-weight: 600;
            white-space: nowrap;
        }

        .remove-queue-message:hover {
            background: #ffe8ec;
            border-color: #eaa7b4;
            color: #9f1239;
        }

        @@keyframes notificationPanelIn {
            0% {
                opacity: 0;
                transform: translateY(-8px) scale(0.98);
            }
            100% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }


            /* Sidebar toggle button */

            #sidebarToggleBtn {
                display: none;
                border-color: #1ca7ec;
                color: #1ca7ec;
            }

            #sidebarToggleBtn:hover {
                background: #1ca7ec;
                color: #fff;
            }

            /* Profile dropdown colors */

            #profileMenu .k-link {
                color: #1ca7ec !important;
            }

            #profileMenu .k-link:hover {
                color: #0ea5e9 !important;
            }

            #profileMenu .k-item:hover>.k-link {
                color: #1ca7ec !important;
            }

            #profileMenu .k-state-selected>.k-link,
            #profileMenu .k-selected>.k-link {
                background: #e0f2fe !important;
                color: #1ca7ec !important;
            }

            /* Dropdown buttons */

            #profileMenu .k-button {
                border-color: #1ca7ec;
                color: #1ca7ec;
            }

            #profileMenu .k-button:hover {
                background: #1ca7ec;
                color: white;
            }

            /* Sidebar overlay */

            .sidebar-backdrop {
                display: none;
            }

            /* Mobile layout */

            @@media (max-width: 991px) {

                .admin-sidebar {
                    width: min(82vw, 290px);
                    position: fixed !important;
                    top: var(--topbar-height);
                    left: 0;
                    bottom: 0;
                    height: auto;
                    z-index: 45;
                    transform: translateX(-105%);
                    transition: transform 0.25s ease;
                    box-shadow: 8px 0 20px rgba(15, 23, 42, 0.16);
                }

                .admin-shell.sidebar-open .admin-sidebar {
                    transform: translateX(0);
                }

                #sidebarToggleBtn {
                    display: inline-flex;
                }

                .sidebar-backdrop {
                    display: block;
                    position: fixed;
                    inset: var(--topbar-height) 0 0 0;
                    background: rgba(15, 23, 42, 0.3);
                    opacity: 0;
                    visibility: hidden;
                    transition: opacity 0.25s ease;
                    z-index: 30;
                }

                .admin-shell.sidebar-open .sidebar-backdrop {
                    opacity: 1;
                    visibility: visible;
                }

                body.sidebar-open-mobile {
                    overflow: hidden;
                }
            }
    </style>
</head>

<body class="text-dark">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <div class="admin-shell d-flex min-vh-100">
        <aside class="admin-sidebar position-sticky bg-white border-end p-3 d-flex flex-column gap-3">
            <div class="pb-2 border-bottom">
                <h1 class="h5 mb-1 fw-bold">AMS Admin</h1>
            </div>

            <ul id="adminSidebarPanelBar" class="mb-0" style="align-items: center;">
                <li class="@(currentController == "Admin" && currentAction == "Dashboard" ? "k-selected" : "")">
                    <a href="@Url.Action("Dashboard", "Admin")">
                        <div class="row">
                            <div class="col-3">
                                <i class="fi fi-rr-dashboard" style="margin-right: 8%;font-size:18px"></i>
                            </div>
                            <div class="col">
                                Dashboard
                            </div>
                        </div>
                    </a>
                </li>
                <li class="@(currentController == "Admin" && currentAction == "History" ? "k-selected" : "")">
                    <a href="@Url.Action("History", "Admin")">
                        <div class="row">
                            <div class="col-2">
                                <i class="fi fi-rr-time-past" style="margin-right: 8%;font-size:18px"></i>
                            </div>
                            <div class="col">
                                Attendance History
                            </div>
                        </div>
                    </a>
                </li>
                <li class="@(currentController == "Admin" && currentAction == "AccessControl" ? "k-selected" : "")">
                    <a href="@Url.Action("AccessControl", "Admin")">
                        <div class="row">
                            <div class="col-2">
                                <i class="fi fi-rr-user-key" style="margin-right: 8%;font-size:18px"></i>
                            </div>
                            <div class="col" style="align-items: center;">
                                Employee Access
                            </div>
                        </div>
                    </a>
                </li>
                <li class="@(currentController == "Admin" && currentAction == "ProgressReport" ? "k-selected" : "")">
                    <a href="@Url.Action("ProgressReport", "Admin")">
                        <div class="row">
                            <div class="col-2">
                                <i class="fi fi-rr-newspaper" style="margin-right: 8%;font-size:18px"></i>
                            </div>
                            <div class="col" style="align-items: center;">
                                Progress Report
                            </div>
                        </div>
                    </a>
                </li>
            </ul>
        </aside>

        <div class="sidebar-backdrop d-lg-none"></div>

        <div class="admin-main flex-grow-1 d-flex flex-column min-vh-100">
            <header
                class="admin-topbar sticky-top bg-white border-bottom px-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <button id="sidebarToggleBtn" type="button" class="btn btn-outline-secondary btn-sm">Menu</button>
                </div>

                <div class="d-flex align-items-center ms-auto gap-3">
                    <div class="bell-wrapper">
                        <div class="bell-icon" id="bellIcon">
                            <div class="icon">
                                <i class="fi fi-rr-bell-notification-social-media"></i>
                            </div>
                            <span class="notification-count is-hidden" id="notificationCount">0</span>
                        </div>
                        <div class="notification-panel" id="notificationPopup">
                            <div class="notification-panel-header">Notifications</div>
                            <div class="card-body p-2" id="notificationList">
                                <p class="mb-0">No notifications</p>
                            </div>
                        </div>
                    </div>

                    <ul id="profileMenu" class="ms-auto mb-0">
                        <li>
                            <span class="profile-trigger" aria-label="Profile options">
                                <span class="k-icon k-i-user"></span>
                            </span>
                            <ul>
                                <li>
                                    <div class="card border-0 shadow-sm" style="width: 260px;">
                                        <div class="card-body p-3">
                                            <p class="mb-0 fw-bold">Admin</p>
                                            <a id="logoutBtn" href="@Url.Action("Logout", "User")" class="w-100">Logout</a>
                                        </div>
                                    </div>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </header>

            <main class="p-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
            $(function () {
                var $shell = $(".admin-shell");
                var $body = $("body");
                var getQueueMessagesUrl = '@Url.Action("GetQueueMessages", "Admin")';
                var removeQueueMessageUrl = '@Url.Action("RemoveQueueMessage", "Admin")';


                $("#adminSidebarPanelBar").kendoPanelBar({
                    expandMode: "single",
                    select: function () {
                        if (window.matchMedia("(max-width: 991px)").matches) {
                            $shell.removeClass("sidebar-open");
                            $body.removeClass("sidebar-open-mobile");
                        }
                    }
                });

                $("#profileMenu").kendoMenu({
                    orientation: "horizontal",
                    openOnClick: false,
                    hoverDelay: 60
                });

                $("#sidebarToggleBtn").kendoButton({
                    icon: "menu"
                });

                $("#sidebarToggleBtn").on("click", function () {
                    $shell.toggleClass("sidebar-open");
                    $body.toggleClass("sidebar-open-mobile", $shell.hasClass("sidebar-open"));
                });

                $("#viewProfileBtn").kendoButton({
                    icon: "user"
                });

                $("#logoutBtn").kendoButton({
                    icon: "logout"
                });
            $("#bellIcon").on("click", function (e) {
                e.stopPropagation();
                const popup = $("#notificationPopup");
                popup.toggleClass("show");
                $("#bellIcon").toggleClass("active", popup.hasClass("show"));
                if (popup.hasClass("show")) {
                    loadQueueMessages();
                }
            });

            $("#notificationPopup").on("click", function (e) {
                e.stopPropagation();
            });

            $(document).on("click", function () {
                $("#notificationPopup").removeClass("show");
                $("#bellIcon").removeClass("active");
            });

                $(".sidebar-backdrop").on("click", function () {
                    $shell.removeClass("sidebar-open");
                    $body.removeClass("sidebar-open-mobile");
                });

                $(window).on("resize", function () {
                    if (!window.matchMedia("(max-width: 991px)").matches) {
                        $shell.removeClass("sidebar-open");
                        $body.removeClass("sidebar-open-mobile");
                    }
                });
                
            function renderNotificationSection(title, items) {
                const section = $('<div class="notification-section"></div>');
                section.append(`<div class="notification-section-title">${title}</div>`);

                const body = $('<div class="notification-section-body"></div>');

                if (!items || !items.length) {
                    body.html('<div class="notification-empty">No notifications</div>');
                    section.append(body);
                    return section;
                }

                items.forEach(function (item) {
                    const timeText = item.displayTime ? `<span class="notification-time">${item.displayTime}</span>` : "";
                    const safeNotificationId = String(item.id || "").replace(/'/g, "\\'");
                    const notification = $(`
                        <div class="notification-item" data-id="${item.id}">
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <strong>${item.title}</strong><br />
                                    <span>${item.message}</span>
                                    ${timeText}
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-queue-message" onclick="removeQueueMessage('${safeNotificationId}'); return false;">Remove</button>
                            </div>
                        </div>
                    `);
                    body.append(notification);
                });

                section.append(body);
                return section;
            }

            function renderNotificationList(registrationItems, attendanceItems) {
                const container = $("#notificationList");
                container.empty();
                container
                    .append(renderNotificationSection("Registrations", registrationItems))
                    .append(renderNotificationSection("Clocks", attendanceItems));
            }

            function updateNotificationCount(total) {
                const count = Number(total) || 0;
                const badge = $("#notificationCount");
                if (count > 0) {
                    badge.text(count > 99 ? "99+" : count);
                    badge.removeClass("is-hidden");
                } else {
                    badge.text("0");
                    badge.addClass("is-hidden");
                }
            }

            window.loadQueueMessages = function () {
                $.get(getQueueMessagesUrl, function (response) {
                    if (!response || !response.success) {
                        $("#notificationList").html('<div class="notification-empty">Unable to load notifications</div>');
                        updateNotificationCount(0);
                        return;
                    }

                    const registrationMessages = response.registrationMessages || [];
                    const attendanceMessages = response.attendanceMessages || [];
                    renderNotificationList(registrationMessages, attendanceMessages);
                    updateNotificationCount(registrationMessages.length + attendanceMessages.length);
                }).fail(function () {
                    $("#notificationList").html('<div class="notification-empty">Unable to load notifications</div>');
                    updateNotificationCount(0);
                });
            };

            window.removeQueueMessage = function (notificationId) {
                if (!notificationId) {
                    return;
                }
                
                $.ajax({
                    url: removeQueueMessageUrl,
                    type: "POST",
                    data: { notificationId: notificationId },
                    success: function (response) {
                        if (response && response.success) {
                            window.loadQueueMessages();
                        }
                    },
                    error: function () {
                        window.loadQueueMessages();
                    }
                });
            };

            loadQueueMessages();

    });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
