<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/kendo/kendo.default-v2.min.css" />
    <link rel='stylesheet' href='https://cdn-uicons.flaticon.com/3.0.0/uicons-regular-rounded/css/uicons-regular-rounded.css' />


    <style>
        :root {
            --sidebar-width: 250px !important;
            --topbar-height: 64px;
        }

        html, body {
            height: 100%;
        }

        body {
            background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }

        .employee-sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            top: 0;
        }

        .employee-topbar {
            height: var(--topbar-height);
            z-index: 20;
            background: linear-gradient(180deg, #ffffff 0%, #f5f8ff 100%) !important;
            border-bottom: 1px solid #dbe4f6 !important;
        }

        #employeeSidebarPanelBar {
            border: none;
            background: transparent;
        }

        #employeeSidebarPanelBar .k-link {
            border-radius: 0.5rem;
            margin: 0.2rem 0;
            font-weight: 600;
            color: #0b6e99;
            margin-bottom: 10px;
        }

        #employeeSidebarPanelBar .k-selected > .k-link,
        #employeeSidebarPanelBar .k-state-selected > .k-link {
            background: #e0f2fe;
            color: #0b6e99;
        }

        #profileMenu {
            border: none;
            background: transparent;
        }

        #profileMenu > .k-item > .k-link {
            padding: 0;
            border: none;
            background: transparent;
        }

        #profileMenu .k-animation-container {
            margin-top: 0.5rem;
        }

        .profile-trigger {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 2px solid #dbeafe;
            background: #f0f9ff;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .profile-trigger img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .work-actions {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            margin-left: 0.75rem;
        }

        .work-actions .k-button {
            border-radius: 8px;
            border-color: transparent;
        }

        .work-actions #startWorkBtn.k-button {
            background: #4f6bed;
            color: #fff;
        }

        .work-actions #startWorkBtn.k-button:hover {
            background: #3f5ad6;
        }

        .work-actions #endWorkBtn.k-button {
            background: #eef2ff;
            color: #1f2937;
            border-color: #d6dcf4;
        }

        .work-actions #endWorkBtn.k-button:hover {
            background: #e4e8f1;
        }

        .work-timer {
            min-width: 86px;
            text-align: center;
            font-weight: 700;
            color: #1f2937;
            background: #eef2ff;
            border: 1px solid #dbeafe;
            border-radius: 0.5rem;
            padding: 0.25rem 0.5rem;
        }

        .work-popup {
            padding: 0.25rem;
        }

        .work-popup label {
            font-weight: 600;
            margin-bottom: 0.4rem;
            display: inline-block;
        }

        .task-checklist {
            display: grid;
            gap: 0.5rem;
        }

        .task-check-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.35rem 0.5rem;
            border: 1px solid #e5e7eb;
            border-radius: 0.45rem;
            background: #f9fafb;
        }

        .task-check-item input {
            margin: 0;
        }

        #startWorkPopup .k-window-content,
        #endWorkPopup .k-window-content {
            background: #f8fbff;
        }

        #profileMenu .k-menu-link {
            background: transparent !important;
        }

        .sidebar-backdrop {
            display: none;
        }

        #sidebarToggleBtn {
            display: none;
        }

        @@media (max-width: 991px) {
            .employee-sidebar {
                width: min(82vw, 290px);
                position: fixed !important;
                top: var(--topbar-height);
                left: 0;
                bottom: 0;
                height: auto;
                z-index: 45;
                transform: translateX(-105%);
                transition: transform 0.25s ease;
                box-shadow: 8px 0 20px rgba(15, 23, 42, 0.16);
            }

            .employee-shell.sidebar-open .employee-sidebar {
                transform: translateX(0);
            }

            #sidebarToggleBtn {
                display: inline-flex;
            }

            .work-actions {
                margin-left: 0.4rem;
                gap: 0.3rem;
            }

            .work-timer {
                font-size: 0.85rem;
                min-width: 74px;
            }

            .sidebar-backdrop {
                display: block;
                position: fixed;
                inset: var(--topbar-height) 0 0 0;
                background: rgba(15, 23, 42, 0.3);
                opacity: 0;
                visibility: hidden;
                transition: opacity 0.25s ease;
                z-index: 30;
            }

            .employee-shell.sidebar-open .sidebar-backdrop {
                opacity: 1;
                visibility: visible;
            }

            body.sidebar-open-mobile {
                overflow: hidden;
            }
        }
        .dashboard {
            margin: auto;
            padding: 30px;
        }

        .dashboard .controls {
            margin-bottom: 25px;
        }

        .dashboard .periodBtn {
            padding: 10px 18px;
            border: none;
            border-radius: 6px;
            margin-right: 10px;
            background: #e4e8f1;
            cursor: pointer;
            font-weight: 500;
            transition: 0.3s;
        }

        .dashboard .periodBtn:hover {
            background: #d4daea;
        }

        .dashboard .periodBtn.active {
            background: #4f6bed;
            color: white;
        }

        .dashboard .cards {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .dashboard .card {
            flex: 1;
            min-width: 180px;
            background: white;
            border-radius: 10px;
            padding: 15px;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
        }

        .dashboard .card-title {
            font-size: 14px;
            color: #777;
        }

        .dashboard .card-value {
            font-size: 32px;
            font-weight: bold;
            margin-top: 8px;
        }

        .dashboard .total {
            border-left: 5px solid #4f6bed;
        }

        .dashboard .avg {
            border-left: 5px solid #00b894;
        }

        .dashboard .latein {
            border-left: 5px solid #ed4f4f;
        }

        .dashboard .earlyout {
            border-left: 5px solid #b80065;
        }

        .dashboard .chartCard {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
        }
    </style>
</head>
<body class="text-dark">
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var employeeName = Context.Session.GetString("EmployeeName") ?? "Employee";
        var profileImage = Context.Session.GetString("ProfileImage") ?? "";
        var employeeId = Context.Session.GetInt32("EmployeeId") ?? 0;
        var defaultProfileImage = "https://cdn-icons-png.flaticon.com/512/847/847969.png";
        var topProfileSrc = !string.IsNullOrWhiteSpace(profileImage)
            ? Url.Content($"~/profile_images/{profileImage}")
            : defaultProfileImage;
    }

    <div class="employee-shell d-flex min-vh-100">
        <aside class="employee-sidebar position-sticky bg-white border-end p-3 d-flex flex-column gap-3">
            <div class="pb-2 border-bottom">
                <h1 class="h5 mb-1 fw-bold">AMS Employee</h1>
                <p class="mb-0 text-muted small">Attendance & profile workspace</p>
            </div>

            <ul id="employeeSidebarPanelBar" class="mb-0">
                <li class="@(currentController == "Employee" && currentAction == "Dashboard" ? "k-selected" : "")">
                    <a href="@Url.Action("Dashboard", "Employee")">
                        <span class="fi fi-rr-dashboard me-2"></span>
                        Dashboard
                    </a>
                </li>
                <li class="@(currentController == "Employee" && currentAction == "UpdateUser" ? "k-selected" : "")">
                    <a href="@Url.Action("UpdateUser", "Employee")">
                        <span class="fi fi-rr-edit me-2"></span>
                        Profile
                    </a>
                </li>
            </ul>
        </aside>

        <div class="sidebar-backdrop d-lg-none"></div>

        <div class="employee-main flex-grow-1 d-flex flex-column min-vh-100">
            <header class="employee-topbar sticky-top bg-white border-bottom px-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <button id="sidebarToggleBtn" type="button" class="btn btn-outline-secondary btn-sm">Menu</button>
                    <div class="work-actions">
                        <button id="startWorkBtn" type="button">Start</button>
                        <button id="endWorkBtn" type="button" class="d-none">End</button>
                        <span id="workTimer" class="work-timer">00:00:00</span>
                    </div>
                </div>

                <ul id="profileMenu" class="ms-auto mb-0">
                    <li>
                        <span class="profile-trigger" aria-label="Profile options">
                            <img id="topProfileImage" src="@topProfileSrc" alt="Profile" />
                        </span>
                        <ul>
                            <li>
                                <div class="card border-0 shadow-sm" style="width: 260px;">
                                    <div class="card-body p-3">
                                        <p class="mb-0 fw-bold">@employeeName</p>
                                        <p class="mb-2 text-muted small">Employee</p>
                                        <a id="viewProfileBtn" href="@Url.Action("UpdateUser", "Employee")" class="w-100 mb-2">View Profile</a>
                                        <a id="logoutBtn" href="@Url.Action("Logout", "User")" class="w-100">Logout</a>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </li>
                </ul>
            </header>

            <main class="p-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <div id="startWorkPopup" style="display:none;">
        <div class="work-popup">
            <label for="workTypeSelect">Work-Type</label>
            <input id="workTypeSelect" />
            <div class="mt-3 d-flex justify-content-end">
                <button id="submitStartWorkBtn" type="button">Submit</button>
            </div>
        </div>
    </div>

    <div id="endWorkPopup" style="display:none;">
        <div class="work-popup">
            <label>Task-Type</label>
            <div class="task-checklist">
                <label class="task-check-item">
                    <input type="checkbox" name="taskType" value="Developing" />
                    <span>Developing</span>
                </label>
                <label class="task-check-item">
                    <input type="checkbox" name="taskType" value="Designing" />
                    <span>Designing</span>
                </label>
                <label class="task-check-item">
                    <input type="checkbox" name="taskType" value="Research" />
                    <span>Research</span>
                </label>
            </div>
            <div class="mt-3 d-flex justify-content-end">
                <button id="submitEndWorkBtn" type="button">Submit</button>
            </div>
        </div>
    </div>

    <span id="workNotification"></span>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/kendo/kendo.all.min.js"></script>
    <script>
        $(function () {
            var $shell = $(".employee-shell");
            var $body = $("body");

            $("#employeeSidebarPanelBar").kendoPanelBar({
                expandMode: "single",
                select: function () {
                    if (window.matchMedia("(max-width: 991px)").matches) {
                        $shell.removeClass("sidebar-open");
                        $body.removeClass("sidebar-open-mobile");
                    }
                }
            });

            $("#profileMenu").kendoMenu({
                orientation: "horizontal",
                openOnClick: false,
                hoverDelay: 60
            });

            $("#sidebarToggleBtn").kendoButton({
                icon: "menu"
            });

            $("#sidebarToggleBtn").on("click", function () {
                $shell.toggleClass("sidebar-open");
                $body.toggleClass("sidebar-open-mobile", $shell.hasClass("sidebar-open"));
            });

            $("#viewProfileBtn").kendoButton({
                icon: "user"
            });

            $("#logoutBtn").kendoButton({
                icon: "logout"
            });

            $("#startWorkBtn").kendoButton({
                icon: "play",
                themeColor: "primary"
            });

            $("#endWorkBtn").kendoButton({
                icon: "stop",
                fillMode: "outline"
            });

            $("#submitStartWorkBtn").kendoButton({
                icon: "check",
                themeColor: "primary"
            });

            $("#submitEndWorkBtn").kendoButton({
                icon: "check",
                themeColor: "primary"
            });

            $("#workTypeSelect").kendoDropDownList({
                optionLabel: "Select Work Type",
                dataSource: ["Remote", "Office", "Field Work"]
            });

            const startPopup = $("#startWorkPopup").kendoWindow({
                title: "Start Work",
                modal: true,
                visible: false,
                width: 360,
                resizable: false,
                draggable: true,
                actions: ["Close"]
            }).data("kendoWindow");

            const endPopup = $("#endWorkPopup").kendoWindow({
                title: "End Work",
                modal: true,
                visible: false,
                width: 360,
                resizable: false,
                draggable: true,
                actions: ["Close"]
            }).data("kendoWindow");

            const notification = $("#workNotification").kendoNotification({
                position: { top: 80, right: 24 },
                stacking: "down",
                autoHideAfter: 2500
            }).data("kendoNotification");

            let timerInterval = null;
            let startTime = null;
            const employeeId = @employeeId;
            const defaultProfileImage = "@defaultProfileImage";

            if (employeeId > 0) {
                $.ajax({
                    url: "/Employee/GetUserById",
                    type: "GET",
                    data: { EmployeeId: employeeId },
                    success: function (res) {
                        if (res && res.success && res.data && res.data.image) {
                            $("#topProfileImage").attr("src", "/profile_images/" + res.data.image);
                        }
                    },
                    error: function () {
                        $("#topProfileImage").attr("src", defaultProfileImage);
                    }
                });
            }

            function showNotice(message, type) {
                notification.show(message, type || "info");
            }

            function updateTimerText() {
                if (!startTime) {
                    $("#workTimer").text("00:00:00");
                    return;
                }

                const now = new Date();
                const diff = now - startTime;
                const hours = Math.floor(diff / 1000 / 60 / 60);
                const minutes = Math.floor((diff / 1000 / 60) % 60);
                const seconds = Math.floor((diff / 1000) % 60);

                $("#workTimer").text(
                    String(hours).padStart(2, "0") + ":" +
                    String(minutes).padStart(2, "0") + ":" +
                    String(seconds).padStart(2, "0")
                );
            }

            function startTimer(fromStorage) {
                if (timerInterval) {
                    clearInterval(timerInterval);
                }

                if (!startTime) {
                    startTime = fromStorage ? new Date(fromStorage) : new Date();
                }

                sessionStorage.setItem("workStartedAt", startTime.toISOString());
                sessionStorage.setItem("workInProgress", "1");

                updateTimerText();
                timerInterval = setInterval(updateTimerText, 1000);

                $("#startWorkBtn").addClass("d-none");
                $("#endWorkBtn").removeClass("d-none");
            }

            function stopTimer() {
                if (timerInterval) {
                    clearInterval(timerInterval);
                    timerInterval = null;
                }

                startTime = null;
                sessionStorage.removeItem("workStartedAt");
                sessionStorage.removeItem("workInProgress");
                $("#workTimer").text("00:00:00");
                $("#endWorkBtn").addClass("d-none");
                $("#startWorkBtn").removeClass("d-none");
            }

            const storedStart = sessionStorage.getItem("workStartedAt");
            const inProgress = sessionStorage.getItem("workInProgress") === "1";
            if (storedStart && inProgress) {
                startTimer(storedStart);
            }

            $("#startWorkBtn").on("click", function () {
                startPopup.center().open();
            });

            $("#submitStartWorkBtn").on("click", function () {
                const workType = $("#workTypeSelect").data("kendoDropDownList").value();
                if (!workType) {
                    showNotice("Please select work type.", "warning");
                    return;
                }

                $.ajax({
                    url: "/Employee/ClockIn",
                    type: "POST",
                    data: { workType: workType },
                    success: function (res) {
                        if (res && res.success) {
                            startTime = new Date();
                            startTimer();
                            startPopup.close();
                            showNotice(res.message || "Clock-In successful.", "success");
                        } else {
                            showNotice(res?.message || "Clock-In failed.", "error");
                        }
                    },
                    error: function (xhr) {
                        showNotice(xhr?.responseJSON?.message || "Clock-In request failed.", "error");
                    }
                });
            });

            $("#endWorkBtn").on("click", function () {
                endPopup.center().open();
            });

            $("#submitEndWorkBtn").on("click", function () {
                const selectedTasks = $("input[name='taskType']:checked").map(function () {
                    return $(this).val();
                }).get();

                if (!selectedTasks.length) {
                    showNotice("Please select at least one task type.", "warning");
                    return;
                }

                $.ajax({
                    url: "/Employee/ClockOut",
                    type: "POST",
                    traditional: true,
                    data: { taskTypes: selectedTasks },
                    success: function (res) {
                        if (res && res.success) {
                            stopTimer();
                            $("input[name='taskType']").prop("checked", false);
                            endPopup.close();
                            showNotice(res.message || "Clock-Out successful.", "success");
                        } else {
                            showNotice(res?.message || "Clock-Out failed.", "error");
                        }
                    },
                    error: function (xhr) {
                        showNotice(xhr?.responseJSON?.message || "Clock-Out request failed.", "error");
                    }
                });
            });

            $(".sidebar-backdrop").on("click", function () {
                $shell.removeClass("sidebar-open");
                $body.removeClass("sidebar-open-mobile");
            });

            $(window).on("resize", function () {
                if (!window.matchMedia("(max-width: 991px)").matches) {
                    $shell.removeClass("sidebar-open");
                    $body.removeClass("sidebar-open-mobile");
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
