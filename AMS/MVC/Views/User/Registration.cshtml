<style>

body{
    background: linear-gradient(135deg,#667eea,#764ba2);
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
}

.card{
    border:none;
    border-radius:15px;
    width:450px;
}

.card-body{
    padding:40px;
}

.form-title{
    text-align:center;
    font-weight:600;
    margin-bottom:25px;
}

.profile-container{
    text-align:center;
    margin-bottom:25px;
}

.profile-border{
    width:130px;
    height:130px;
    border-radius:50%;
    background: linear-gradient(135deg,#667eea,#764ba2);
    padding:2px;
    margin:auto;
}

.profile-img{
    width:100%;
    height:100%;
    border-radius:50%;
    object-fit:cover;
    cursor:pointer;
    background:white;
}

.upload-text{
    font-size:13px;
    color:#777;
    margin-top:8px;
}

.k-textbox{
    width:100%;
}

.k-form-error{
    color:red;
    font-size:12px;
}

.submit-btn{
    width:100%;
    border-radius:8px;
    padding:10px;
    font-weight:600;
    background: linear-gradient(135deg,#667eea,#764ba2);
}

.k-form-field-wrap{
    display:flex;
    flex-direction:column;
}

.k-radio-list{
    display:flex;
    gap:20px;
}

</style>


<div class="card shadow-lg">

<div class="card-body">

<h4 class="form-title">Create Account</h4>

<div class="profile-container">

<div class="profile-border">
    <img id="preview" src="https://cdn-icons-png.flaticon.com/512/847/847969.png" class="profile-img">
</div>
<input type="file" id="profileImageInput" name="profileImage" hidden>



</div>

<form id="form"></form>

</div>
</div>


@section Scripts{
<script>

$(document).ready(function(){

/* Click image to open file */
$("#preview").click(function(){
$("#profileImageInput").click();
});

/* Image preview */
$("#profileImageInput").change(function(){

const file=this.files[0];

if(file){

const reader=new FileReader();

reader.onload=function(e){
$("#preview").attr("src",e.target.result);
}

reader.readAsDataURL(file);

}

});


$("#form").kendoForm({

formData:{
name:"",
email:"",
password:"",
gender:""
},

validatable:{
validateOnBlur:true,
validationSummary:false,
errorTemplate:"<span class='k-form-error'>#:message#</span>"
},

items:[

{
field:"name",
label:"Full Name",
editor:"TextBox",
validation:{
required:{message:"Enter your name"}
},
editorOptions:{
placeholder:"Enter your name"
}
},

{
field:"email",
label:"Email",
editor:"TextBox",
validation:{
required:{message:"Enter email"},
email:true
},
editorOptions:{
placeholder:"Enter your email"
}
},

{
field:"password",
label:"Password",
editor:"TextBox",
validation:{
required:{message:"Enter password"}
},
attributes:{
type:"password",
placeholder:"Enter password"
}
},

{
                field: "Gender",
                label: "Gender:",
                editor: function (container, options) {
                    const genderOptions = [
                        { value: "Male", label: "Male" },
                        { value: "Female", label: "Female" },
                        { value: "Other", label: "Other" }
                    ];
                    $('<div class="k-radio-group"></div>')
                    .appendTo(container);
                    genderOptions.forEach((option,index) => {
                        $('<label class="k-radio-label"></label>')
                        .append(
                        $('<input type="radio" style="margin:5px" name="' + options.field + '" value="' + option.value + '" '+(index === genderOptions.length - 1 ? 'required' : '')+' />')
                        )
                        .append(option.label)
                        .appendTo(container.find(".k-radio-group"));
                    });
                },
                
                validation: { required: { message: "Please select your gender." } },
            },

],

buttonsTemplate:
'<button class="btn btn-primary submit-btn mt-3">Register</button>',

submit:function(e){

e.preventDefault();

let formdata=new FormData();

formdata.append("name",$("input[name='name']").val());
formdata.append("email",$("input[name='email']").val());
formdata.append("password",$("input[name='password']").val());
formdata.append("gender",$("input[name='gender']:checked").val());
formdata.append("profileImage",$("#profileImageInput")[0].files[0]);

$.ajax({

url:"/Home/Register",
type:"POST",
data:formdata,
contentType:false,
processData:false,

success:function(res){

alert("Registration Successful");

console.log(res);

}

});

}

});

});

</script>
}