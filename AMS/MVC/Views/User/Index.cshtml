@{
    ViewData["Title"] = "Home";
}


<style>
    /* ---------- GLOBAL ---------- */

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        overflow-x: hidden;
    }

    /* ---------- BACKGROUND ANIMATION ---------- */

    body::before {
        content: "";
        position: absolute;
        width: 500px;
        height: 500px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        top: -150px;
        left: -150px;
        animation: float 8s infinite alternate;
    }

    body::after {
        content: "";
        position: absolute;
        width: 400px;
        height: 400px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
        bottom: -150px;
        right: -150px;
        animation: float 10s infinite alternate;
    }

    @@keyframes float {
        from {
            transform: translateY(0px);
        }

        to {
            transform: translateY(40px);
        }
    }

    /* ---------- HERO ---------- */

    .hero {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

    .hero-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        width: 1100px;
    }

    /* ---------- HERO TEXT ---------- */

    .hero-text {
        color: white;
    }

    .hero-text h1 {
        font-size: 48px;
        margin-bottom: 20px;
    }

    .hero-text p {
        font-size: 18px;
        margin-bottom: 30px;
    }

    /* ---------- BUTTONS ---------- */

    .btn-group {
        display: flex;
        gap: 20px;
    }

    .btn-main {
        padding: 12px 30px;
        border-radius: 30px;
        font-weight: 600;
        text-decoration: none;
        transition: .3s;
    }

    .btn-login {
        background: white;
        color: #4e73df;
    }

    .btn-login:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25);
    }

    .btn-register {
        background: #222;
        color: white;
    }

    .btn-register:hover {
        background: black;
        transform: translateY(-3px);
    }

    /* ---------- GLASS CARD ---------- */

    .glass-card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.25);
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    /* ---------- FEATURES ---------- */

    .features {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
    }

    .feature {
        background: white;
        padding: 25px;
        border-radius: 14px;
        text-align: center;
        transition: all .35s ease;
        position: relative;
        overflow: hidden;
    }

    /* gradient top bar */

    .feature::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #4e73df, #1cc88a);
    }

    /* icon style */

    .feature i {
        font-size: 30px;
        color: white;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: auto;
        margin-bottom: 15px;
        transition: 0.3s;
    }

    .feature:hover i {
        transform: scale(1.1);
        box-shadow: 0 0 15px rgba(78, 115, 223, 0.5);
    }

    /* title */

    .feature h4 {
        margin-bottom: 8px;
        font-weight: 600;
        color: #333;
    }

    /* text */

    .feature p {
        font-size: 14px;
        color: #666;
    }

    /* hover animation */

    .feature:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
    }

    /* glow hover */

    .feature:hover i {
        box-shadow: 0 0 15px rgba(78, 115, 223, 0.6);
    }



    /* ---------- RESPONSIVE ---------- */

    @@media(max-width:900px) {

        .hero-container {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .btn-group {
            justify-content: center;
        }

    }
</style>


<!-- HERO -->

<section class="hero">

    <div class="hero-container">

        <!-- LEFT SIDE -->

        <div class="hero-text">
            <h1>Attendance Management System</h1>

            <p>
                A smart platform to track employee attendance, working hours,
                and task activities with powerful reporting and admin dashboard.
            </p>

            <div class="btn-group">
                <a href="/User/Login" class="btn-main btn-login">
                    Login
                </a>

                <a href="/User/Register" class="btn-main btn-register">
                    Register
                </a>
            </div>
        </div>

        <!-- RIGHT SIDE -->

        <div class="glass-card">
            <h2 style="text-align:center;margin-bottom:25px;">About The System</h2>
            <div class="features">
                <div class="feature">
                    <i class="fi fi-rr-user-check"></i>
                    <h4>Attendance</h4>
                    <p>Employees mark daily clock-in and clock-out.</p>
                </div>

                <div class="feature">
                    <i class="fi fi-rr-laptop"></i>
                    <h4>Work Types</h4>
                    <p>Remote, Office, or Field work tracking.</p>
                </div>

                <div class="feature">
                    <i class="fi fi-rr-chart-histogram"></i>
                    <h4>Task Monitoring</h4>
                    <p>Track development, research and design work.</p>
                </div>

                <div class="feature">
                    <i class="fi fi-rr-dashboard"></i>
                    <h4>Admin Dashboard</h4>
                    <p>View attendance reports and employee stats.</p>
                </div>
            </div>
        </div
    </div>
</section>