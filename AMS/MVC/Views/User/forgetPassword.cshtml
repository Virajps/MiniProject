@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-shell forgot-shell">
    <div class="auth-lottie forgot-lottie">
        <iframe class="auth-lottie-frame forgot-lottie-frame"  src="https://lottie.host/embed/a040e80d-5e45-4d1d-8a97-7ff32cecb8d7/ueUocxHR3k.lottie" title="Forgot password animation" loading="lazy"></iframe>
    </div>

    <div class="card shadow-lg auth-card forgot-card">
        <div class="card-body">

            <h4 class="form-title">Reset Password</h4>
            <p class="form-subtitle text-muted mb-4">No worries! We'll send you reset instructions.</p>

            <!-- Progress Steps -->
            <div class="progress-steps mb-4">
                <div class="progress-step active" id="stepIndicator1">
                    <div class="step-circle">1</div>
                    <div class="step-label">Email</div>
                </div>
                <div class="progress-line"></div>
                <div class="progress-step" id="stepIndicator2">
                    <div class="step-circle">2</div>
                    <div class="step-label">OTP</div>
                </div>
                <div class="progress-line"></div>
                <div class="progress-step" id="stepIndicator3">
                    <div class="step-circle">3</div>
                    <div class="step-label">Reset</div>
                </div>
            </div>

            <!-- STEP 1 -->
            <div id="step1" class="step-content fade-in">
                <div class="k-form-field">
                    <label class="k-form-label">Email Address</label>
                    <input type="email" id="fp_email" class="form-control k-textbox" placeholder="Enter your email" />
                </div>
                <button class="btn btn-primary submit-btn mt-3" onclick="sendOTP()">
                    <span class="btn-text">Send OTP</span>
                    <span class="btn-loader" style="display:none;"></span>
                </button>
            </div>

            <!-- STEP 2 -->
            <div id="step2" class="step-content" style="display:none;">
                <div class="alert alert-info mb-3" role="alert">
                    <i class="fi fi-rr-envelope"></i> We've sent a 6-digit OTP to <strong id="otp_email_display"></strong>
                </div>
                <div class="k-form-field">
                    <label class="k-form-label">Enter OTP Code</label>
                    <input type="text" id="fp_otp" class="form-control k-textbox otp-input" placeholder="Enter 6-digit OTP" maxlength="6" />
                </div>
                <div class="resend-otp-section mt-3">
                    <p class="text-muted mb-2">Didn't receive the code?</p>
                    <button class="btn btn-link resend-link" onclick="resendOTP()" id="resendBtn">
                        <i class="fi fi-rr-refresh"></i> Resend OTP
                    </button>
                    <span id="resendTimer" class="text-muted ms-2"></span>
                </div>
                <button class="btn btn-success submit-btn mt-3" onclick="verifyOTP()">
                    <span class="btn-text">Verify OTP</span>
                    <span class="btn-loader" style="display:none;"></span>
                </button>
            </div>

        </div>
    </div>
</div>

<!-- PASSWORD POPUP -->
<div id="popupOverlay" style="display:none;"></div>
<div id="passwordPopup" class="password-popup" style="display:none;">
    <div class="popup-header">
        <h4 class="popup-title"><i class="fi fi-rr-key"></i> Set New Password</h4>
        <button class="popup-close" onclick="closePasswordPopup()">&times;</button>
    </div>
    <div class="popup-body">
        <p class="popup-subtitle">Create a strong password with at least 8 characters</p>
        <div class="k-form-field">
            <label class="k-form-label">New Password</label>
            <input type="password" id="newPass" class="form-control k-textbox" placeholder="Enter new password" />
        </div>
        <div class="k-form-field">
            <label class="k-form-label">Confirm Password</label>
            <input type="password" id="confirmPass" class="form-control k-textbox" placeholder="Re-enter password" />
        </div>
        <div class="password-match-indicator" id="passwordMatchIndicator">
            <i class="fi fi-rr-check-circle"></i> <span>Passwords match</span>
        </div>
    </div>
    <div class="popup-footer">
        <button class="btn btn-primary submit-btn" onclick="resetPassword()">
            <span class="btn-text">Update Password</span>
            <span class="btn-loader" style="display:none;"></span>
        </button>
        <button class="btn btn-outline-secondary" onclick="closePasswordPopup()">Cancel</button>
    </div>
</div>

<style>
    .form-subtitle {
        font-size: 14px;
        color: #6b7280 !important;
    }

    /* Progress Steps */
    .progress-steps {
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: relative;
    }

    .progress-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        z-index: 1;
    }

    .step-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: #e5e7eb;
        color: #9ca3af;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        transition: all 0.3s ease;
    }

    .progress-step.active .step-circle {
        background: linear-gradient(135deg, var(--sky-500), var(--sky-700));
        color: white;
        box-shadow: 0 4px 12px rgba(58, 162, 255, 0.3);
        transform: scale(1.1);
    }

    .progress-step.completed .step-circle {
        background: #10b981;
        color: white;
    }

    .step-label {
        font-size: 12px;
        color: #9ca3af;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .progress-step.active .step-label,
    .progress-step.completed .step-label {
        color: var(--sky-700);
    }

    .progress-line {
        flex: 1;
        height: 2px;
        background: #e5e7eb;
        margin: 0 8px;
        position: relative;
        top: -18px;
    }

    /* Step Content Animation */
    .step-content {
        animation: fadeInSlide 0.4s ease;
    }

     fadeInSlide {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in {
        animation: fadeInSlide 0.4s ease;
    }

    /* OTP Input */
    .otp-input {
        letter-spacing: 8px;
        font-size: 18px !important;
        text-align: center;
        font-weight: 600 !important;
    }

    /* Resend Section */
    .resend-otp-section {
        text-align: center;
    }

    .resend-link {
        color: var(--sky-600);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        background: none;
        cursor: pointer;
        font-size: 14px;
    }

    .resend-link:hover {
        color: var(--sky-700);
        transform: translateX(3px);
    }

    .resend-link i {
        margin-right: 4px;
    }

    /* Alert */
    .alert-info {
        background: rgba(58, 162, 255, 0.1);
        border: 1px solid rgba(58, 162, 255, 0.3);
        color: var(--sky-700);
        border-radius: 8px;
        font-size: 14px;
    }

    .alert-info i {
        margin-right: 8px;
        font-size: 16px;
    }

    /* Popup Styles */
    #popupOverlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
        z-index: 1040;
        animation: fadeIn 0.3s ease;
    }

    fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .password-popup {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) scale(0.9);
        background: #ffffff;
        padding: 0;
        border-radius: 16px;
        width: 420px;
        max-width: 90vw;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        z-index: 1050;
        animation: popupSlideIn 0.3s ease forwards;
    }

     popupSlideIn {
        from {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.9) translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1) translateY(0);
        }
    }

    .popup-header {
        padding: 24px 28px;
        border-bottom: 1px solid rgba(32, 92, 165, 0.1);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .popup-title {
        font-family: "Space Grotesk", "Manrope", sans-serif;
        font-weight: 700;
        font-size: 20px;
        color: var(--ink-900);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .popup-title i {
        color: var(--sky-600);
    }

    .popup-close {
        background: none;
        border: none;
        font-size: 28px;
        color: #9ca3af;
        cursor: pointer;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.2s ease;
    }

    .popup-close:hover {
        background: rgba(0, 0, 0, 0.05);
        color: var(--ink-900);
    }

    .popup-body {
        padding: 28px;
    }

    .popup-subtitle {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 20px;
    }

    .password-match-indicator {
        margin-top: 12px;
        padding: 10px 14px;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        border-radius: 8px;
        color: #10b981;
        font-size: 13px;
        font-weight: 600;
        display: none;
        align-items: center;
        gap: 8px;
        animation: slideDown 0.3s ease;
    }

    .password-match-indicator.show {
        display: flex;
    }

    .password-match-indicator.error {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.3);
        color: #ef4444;
    }
    slideDown {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .popup-footer {
        padding: 20px 28px;
        background: rgba(248, 250, 252, 0.5);
        border-top: 1px solid rgba(32, 92, 165, 0.1);
        display: flex;
        gap: 12px;
        justify-content: flex-end;
        border-radius: 0 0 16px 16px;
    }

    /* Loading Button */
    .submit-btn {
        position: relative;
        min-width: 120px;
    }

    .btn-loader {
        display: inline-block;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        position: absolute;
        left: 50%;
        top: 50%;
        margin: -9px 0 0 -9px;
    }

    .btn-loading .btn-text {
        visibility: hidden;
    }

    .btn-loading .btn-loader {
        display: block;
    }

     spin {
        to { transform: rotate(360deg); }
    }

    /* Responsive */
     (max-width: 768px) {
        .progress-steps {
            gap: 8px;
        }

        .step-circle {
            width: 32px;
            height: 32px;
            font-size: 14px;
        }

        .step-label {
            font-size: 11px;
        }

        .password-popup {
            width: 95vw;
        }
    }
</style>

<script>
    let resendCountdown = null;

    function sendOTP() {
        let email = $("#fp_email").val().trim();
        
        if (!email) {
            Swal.fire("Error", "Please enter your email address", "error");
            return;
        }

        const $btn = $("#step1 .submit-btn");
        $btn.addClass('btn-loading').prop('disabled', true);

        $.post('/User/SendOTP', { email: email }, function (res) {
            if (res.success) {
                // Update step indicators
                $('#stepIndicator1').addClass('completed');
                $('#stepIndicator2').addClass('active');
                
                // Show email in alert
                $('#otp_email_display').text(email);
                
                Swal.fire({
                    title: "Success!",
                    text: "OTP sent to your email",
                    icon: "success",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    $("#step1").hide();
                    $("#step2").fadeIn(300);
                    $("#fp_otp").focus();
                });
                
                // Start resend timer
                startResendTimer();
            } else {
                Swal.fire("Error", res.message || "Email not found", "error");
                $btn.removeClass('btn-loading').prop('disabled', false);
            }
        }).fail(function() {
            Swal.fire("Error", "Failed to send OTP. Please try again.", "error");
            $btn.removeClass('btn-loading').prop('disabled', false);
        });
    }

    function verifyOTP() {
        let email = $("#fp_email").val().trim();
        let otp = $("#fp_otp").val().trim();

        if (!otp || otp.length !== 6) {
            Swal.fire("Error", "Please enter a valid 6-digit OTP", "error");
            return;
        }

        const $btn = $("#step2 .submit-btn");
        $btn.addClass('btn-loading').prop('disabled', true);

        $.post('/User/VerifyOTP', { email: email, otp: otp }, function (res) {
            if (res.success) {
                // Update step indicators
                $('#stepIndicator2').addClass('completed');
                $('#stepIndicator3').addClass('active');
                
                Swal.fire({
                    title: "Success!",
                    text: "OTP Verified Successfully",
                    icon: "success",
                    timer: 1200,
                    showConfirmButton: false
                }).then(() => {
                    // OPEN POPUP
                    $("#popupOverlay").fadeIn(300);
                    $("#passwordPopup").fadeIn(300);
                    $("#newPass").focus();
                });
            } else {
                Swal.fire("Error", res.message || "Invalid or expired OTP", "error");
                $btn.removeClass('btn-loading').prop('disabled', false);
            }
        }).fail(function() {
            Swal.fire("Error", "Failed to verify OTP. Please try again.", "error");
            $btn.removeClass('btn-loading').prop('disabled', false);
        });
    }

    function resetPassword() {
        let email = $("#fp_email").val().trim();
        let pass = $("#newPass").val();
        let confirm = $("#confirmPass").val();

        if (!pass || pass.length < 8) {
            Swal.fire("Error", "Password must be at least 8 characters long", "error");
            return;
        }

        if (pass !== confirm) {
            Swal.fire("Error", "Passwords do not match", "error");
            return;
        }

        const $btn = $("#passwordPopup .submit-btn");
        $btn.addClass('btn-loading').prop('disabled', true);

        $.post('/User/ResetPassword', { email: email, password: pass }, function (res) {
            if (res.success) {
                Swal.fire({
                    title: "Success!",
                    text: "Password Updated Successfully",
                    icon: "success",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = "/User/Login";
                });
            } else {
                Swal.fire("Error", res.message || "Failed to update password", "error");
                $btn.removeClass('btn-loading').prop('disabled', false);
            }
        }).fail(function() {
            Swal.fire("Error", "An error occurred. Please try again.", "error");
            $btn.removeClass('btn-loading').prop('disabled', false);
        });
    }

    function closePasswordPopup() {
        $("#popupOverlay").fadeOut(300);
        $("#passwordPopup").fadeOut(300);
    }

    function resendOTP() {
        let email = $("#fp_email").val().trim();
        
        if (!email) {
            Swal.fire("Error", "Email is required", "error");
            return;
        }

        const $btn = $("#resendBtn");
        $btn.prop('disabled', true).html('<i class="fi fi-rr-refresh"></i> Sending...');

        $.post('/User/SendOTP', { email: email }, function (res) {
            if (res.success) {
                Swal.fire({
                    title: "Success!",
                    text: "New OTP sent to your email",
                    icon: "success",
                    timer: 1500,
                    showConfirmButton: false
                });
                startResendTimer();
            } else {
                Swal.fire("Error", res.message || "Failed to resend OTP", "error");
            }
        }).fail(function() {
            Swal.fire("Error", "Failed to resend OTP. Please try again.", "error");
        }).always(function() {
            $btn.prop('disabled', false).html('<i class="fi fi-rr-refresh"></i> Resend OTP');
        });
    }

    function startResendTimer() {
        let seconds = 60;
        const $timer = $("#resendTimer");
        const $btn = $("#resendBtn");
        
        $btn.prop('disabled', true);
        
        if (resendCountdown) clearInterval(resendCountdown);
        
        resendCountdown = setInterval(function() {
            seconds--;
            const mins = Math.floor(seconds / 60);
            const secs = seconds % 60;
            $timer.text(`(${mins}:${secs.toString().padStart(2, '0')})`);
            
            if (seconds <= 0) {
                clearInterval(resendCountdown);
                $timer.text('');
                $btn.prop('disabled', false);
            }
        }, 1000);
    }

    // Password match indicator
    $(document).on('input', '#confirmPass', function() {
        const newPass = $("#newPass").val();
        const confirmPass = $(this).val();
        const $indicator = $("#passwordMatchIndicator");
        
        if (confirmPass && newPass === confirmPass) {
            $indicator.removeClass('error').addClass('show');
            $indicator.html('<i class="fi fi-rr-check-circle"></i> <span>Passwords match</span>');
        } else if (confirmPass && newPass !== confirmPass) {
            $indicator.removeClass('show').addClass('error');
            setTimeout(() => {
                if (confirmPass && newPass !== confirmPass) {
                    $indicator.addClass('show');
                    $indicator.html('<i class="fi fi-rr-cross-circle"></i> <span>Passwords do not match</span>');
                }
            }, 200);
        } else {
            $indicator.removeClass('show');
        }
    });

    // Close popup on overlay click
    $("#popupOverlay").click(function() {
        closePasswordPopup();
    });

    // OTP input formatting
    $("#fp_otp").on('input', function() {
        this.value = this.value.replace(/[^0-9]/g, '');
    });
</script>
