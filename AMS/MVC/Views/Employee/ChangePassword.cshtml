@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/EmployeeLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h4 class="mb-3">Change Password</h4>
        <div id="changePasswordAlert" class="alert d-none" role="alert"></div>

        <form class="row g-3" id="changePasswordForm">
            <div class="col-md-6">
                <label class="form-label" for="currentPassword">Current Password</label>
                <input id="currentPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="newPassword">New Password</label>
                <input id="newPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <input id="confirmPassword" type="password" />
            </div>

            <div class="col-12">
                <button id="savePasswordBtn" type="submit">Update Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            function showAlert(type, message) {
                const $alert = $("#changePasswordAlert");
                $alert.removeClass("d-none alert-success alert-danger alert-warning");
                $alert.addClass(`alert-${type}`).text(message);

                if (type === "success") {
                    setTimeout(function () {
                        $alert.addClass("d-none").text("");
                    }, 1000);
                }
            }

            $("#currentPassword").kendoTextBox({ placeholder: "Enter current password" });
            $("#newPassword").kendoTextBox({ placeholder: "Enter new password" });
            $("#confirmPassword").kendoTextBox({ placeholder: "Confirm new password" });
            $("#savePasswordBtn").kendoButton({ themeColor: "primary", icon: "lock" });

            $("#changePasswordForm").on("click", function (e) {
                e.preventDefault();

                const oldPassword = $("#currentPassword").data("kendoTextBox").value().trim();
                const newPassword = $("#newPassword").data("kendoTextBox").value().trim();
                const confirmPassword = $("#confirmPassword").data("kendoTextBox").value().trim();

                if (!oldPassword || !newPassword || !confirmPassword) {
                    showAlert("warning", "All fields are required.");
                    return;
                }

                if (newPassword !== confirmPassword) {
                    showAlert("warning", "New password and confirm password do not match.");
                    return;
                }

                $.ajax({
                    url: "/Employee/ChangePassword",
                    type: "POST",
                    data: {
                        OldPassword: oldPassword,
                        NewPassword: newPassword,
                        ConfirmPassword: confirmPassword
                    },
                    success: function (res) {
                        if (res && res.success) {
                            showAlert("success", res.message || "Password updated successfully.");
                            $("#currentPassword").data("kendoTextBox").value("");
                            $("#newPassword").data("kendoTextBox").value("");
                            $("#confirmPassword").data("kendoTextBox").value("");
                        } else {
                            showAlert("danger", res?.message || "Failed to update password.");
                        }
                    },
                    error: function (xhr) {
                        showAlert("danger", xhr?.responseJSON?.message || "Error while changing password.");
                    }
                });
            });
        });
    </script>
}
