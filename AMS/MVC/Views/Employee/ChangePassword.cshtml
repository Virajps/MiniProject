@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/EmployeeLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h4 class="mb-3">Change Password</h4>

        <form class="row g-3" id="changePasswordForm">
            <div class="col-md-6">
                <label class="form-label" for="currentPassword">Current Password</label>
                <input id="currentPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="newPassword">New Password</label>
                <input id="newPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <input id="confirmPassword" type="password" />
            </div>

            <div class="col-12">
                <button id="savePasswordBtn" type="submit">Update Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $("#currentPassword").kendoTextBox({ placeholder: "Enter current password" });
            $("#newPassword").kendoTextBox({ placeholder: "Enter new password" });
            $("#confirmPassword").kendoTextBox({ placeholder: "Confirm new password" });
            $("#savePasswordBtn").kendoButton({ themeColor: "primary", icon: "lock" });
        });
    </script>
}
