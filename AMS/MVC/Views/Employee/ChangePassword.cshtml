@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/EmployeeLayout.cshtml";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h4 class="mb-3">Change Password</h4>
        <div id="changePasswordAlert" class="alert d-none" role="alert"></div>

        <form class="row g-3" id="changePasswordForm">
            <div class="col-md-6">
                <label class="form-label" for="currentPassword">Current Password</label>
                <input id="currentPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="newPassword">New Password</label>
                <input id="newPassword" type="password" />
            </div>

            <div class="col-md-6">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <input id="confirmPassword" type="password" />
            </div>

            <div class="col-12">
                <button id="savePasswordBtn" type="submit">Update Password</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <style>
        .password-toggle-btn {
            position: absolute;
            top: 50%;
            right: 8px;
            transform: translateY(-50%);
            border: none;
            background: transparent;
            padding: 2px;
            color: #6b7280;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
        }

        .password-toggle-btn:hover {
            color: #111827;
        }

        .password-toggle-btn svg {
            width: 18px;
            height: 18px;
            display: block;
        }

        .password-with-toggle {
            position: relative;
        }

        .password-with-toggle input {
            padding-right: 38px !important;
        }
    </style>

    <script>
        $(function () {
            const passwordPattern = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{8,}$/;

            function getEyeIconMarkup(isVisible) {
                if (isVisible) {
                    return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3l18 18"></path><path d="M10.6 10.6a2 2 0 0 0 2.8 2.8"></path><path d="M9.9 4.2A10.5 10.5 0 0 1 12 4c5.2 0 9.3 3.3 10.8 8-0.5 1.5-1.3 2.9-2.4 4"></path><path d="M6.2 6.2C4.6 7.6 3.4 9.6 2.8 12c1.5 4.7 5.6 8 10.8 8 1.6 0 3.1-.3 4.4-.9"></path></svg>';
                }

                return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
            }

            function attachPasswordToggle(inputSelector) {
                const $input = $(inputSelector).first();
                if (!$input.length || $input.data("hasPasswordToggle")) {
                    return;
                }

                const $host = $input.closest(".k-input").length ? $input.closest(".k-input") : $input;
                $host.addClass("password-with-toggle");

                const $toggleBtn = $('<button type="button" class="password-toggle-btn" aria-label="Show password"></button>');
                $toggleBtn.html(getEyeIconMarkup(false));

                $toggleBtn.on("click", function () {
                    const isPassword = $input.attr("type") === "password";
                    const isVisible = isPassword;
                    $input.attr("type", isVisible ? "text" : "password");
                    $toggleBtn.html(getEyeIconMarkup(isVisible));
                    $toggleBtn.attr("aria-label", isVisible ? "Hide password" : "Show password");
                });

                $host.append($toggleBtn);
                $input.data("hasPasswordToggle", true);
            }

            function showAlert(type, message) {
                const $alert = $("#changePasswordAlert");
                $alert.removeClass("d-none alert-success alert-danger alert-warning");
                $alert.addClass(`alert-${type}`).text(message);

                if (type === "success") {
                    setTimeout(function () {
                        $alert.addClass("d-none").text("");
                    }, 1000);
                }
            }

            $("#currentPassword").kendoTextBox({ placeholder: "Enter current password" });
            $("#newPassword").kendoTextBox({ placeholder: "Enter new password" });
            $("#confirmPassword").kendoTextBox({ placeholder: "Confirm new password" });
            $("#savePasswordBtn").kendoButton({ themeColor: "primary", icon: "lock" });
            attachPasswordToggle("#currentPassword");
            attachPasswordToggle("#newPassword");
            attachPasswordToggle("#confirmPassword");

            function submitChangePassword(e) {
                e.preventDefault();

                const oldPassword = $("#currentPassword").data("kendoTextBox").value().trim();
                const newPassword = $("#newPassword").data("kendoTextBox").value().trim();
                const confirmPassword = $("#confirmPassword").data("kendoTextBox").value().trim();

                if (!oldPassword || !newPassword || !confirmPassword) {
                    showAlert("warning", "All fields are required.");
                    return;
                }

                if (newPassword !== confirmPassword) {
                    showAlert("warning", "New password and confirm password do not match.");
                    return;
                }

                if (!passwordPattern.test(newPassword)) {
                    showAlert("warning", "Password must be minimum 8 characters and include 1 uppercase, 1 lowercase, 1 digit, and 1 special character.");
                    return;
                }

                $.ajax({
                    url: "/Employee/ChangePassword",
                    type: "POST",
                    data: {
                        OldPassword: oldPassword,
                        NewPassword: newPassword,
                        ConfirmPassword: confirmPassword
                    },
                    success: function (res) {
                        if (res && res.success) {
                            showAlert("success", res.message || "Password updated successfully.");
                            $("#currentPassword").data("kendoTextBox").value("");
                            $("#newPassword").data("kendoTextBox").value("");
                            $("#confirmPassword").data("kendoTextBox").value("");
                        } else {
                            showAlert("danger", res?.message || "Failed to update password.");
                        }
                    },
                    error: function (xhr) {
                        showAlert("danger", xhr?.responseJSON?.message || "Error while changing password.");
                    }
                });
            }

            $("#changePasswordForm").on("submit", submitChangePassword);
            $("#savePasswordBtn").on("click", submitChangePassword);
        });
    </script>
}
