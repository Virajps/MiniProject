@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/EmployeeLayout.cshtml";
}

<div class="k-card">
    <div class="k-card-body">
        <h3 class="k-card-title mb-3">My Profile</h3>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Name</label>
                <input id="empName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input id="empEmail" />
            </div>
            <div class="col-12">
                <button id="updateProfileBtn">Update Profile</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $("#empName").kendoTextBox({
                placeholder: "Enter your name"
            });

            $("#empEmail").kendoTextBox({
                placeholder: "Enter your email"
            });

            $("#updateProfileBtn").kendoButton({
                themeColor: "primary",
                icon: "save"
            });
        });
    </script>
}
